# ============================================
# CONFIGURACIÓN DE RED - ngrok Tunnels
# ============================================
# Obtén tu auth token desde: https://dashboard.ngrok.com/get-started/your-authtoken

NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Subdominios personalizados (opcional - requiere plan Pro)
# Si no tienes plan Pro, ngrok asignará URLs aleatorias
# MINIO_SUBDOMAIN=mi-minio
# MINIO_CONSOLE_SUBDOMAIN=mi-minio-console
# SONARQUBE_SUBDOMAIN=mi-sonar

# ============================================
# CONFIGURACIÓN MySQL
# ============================================
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=datasppp
MYSQL_USER=sppp
MYSQL_PASSWORD=sppp123

# ============================================
# CONFIGURACIÓN MinIO
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. Copia este archivo como .env: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA hagas commit del archivo .env (ya está en .gitignore si existe)
# 4. Para MySQL externo, usa la URL TCP de ngrok (ver logs)
